# Environment Variable Configuration

## Staging Environment (.env.staging)

NODE_ENV=staging
PORT=3000
REGION=eu-west-1

# Database Configuration (from AWS Secrets Manager)
DATABASE_URL=postgres://postgres:password@ecommerce-db-staging.xxxxxx.rds.amazonaws.com:5432/ecommerce

# JWT Configuration (from AWS Secrets Manager)
JWT_SECRET=staging-secret-key

# AWS Configuration
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012

# API Configuration
API_BASE_URL=https://api.staging.example.com
API_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_DETAILED_MONITORING=true
ENABLE_DETAILED_LOGGING=true

# Email Configuration
SMTP_HOST=staging-smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@staging.example.com
SMTP_FROM=noreply@staging.example.com

# Seed Data
ADMIN_EMAIL=admin@example.com
