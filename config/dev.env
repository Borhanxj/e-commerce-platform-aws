# Environment Variable Configuration

## Development Environment (.env.dev)

NODE_ENV=development
PORT=3000
REGION=us-east-1

# Database Configuration (from AWS Secrets Manager)
DATABASE_URL=postgres://postgres:password@ecommerce-db-dev.xxxxxx.rds.amazonaws.com:5432/ecommerce

# JWT Configuration (from AWS Secrets Manager)
JWT_SECRET=dev-secret-key

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# API Configuration
API_BASE_URL=http://api.dev.localhost:3000
API_TIMEOUT=30000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_DETAILED_MONITORING=false
ENABLE_DETAILED_LOGGING=true

# Email Configuration
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@ecommerce.dev

# Seed Data
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
SALES_MANAGER_EMAIL=salesmanager@example.com
SALES_MANAGER_PASSWORD=salesmanager123456
PRODUCT_MANAGER_EMAIL=productmanager@example.com
PRODUCT_MANAGER_PASSWORD=productmanager123456
