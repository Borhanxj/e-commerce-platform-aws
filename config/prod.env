# Environment Variable Configuration

## Production Environment (.env.prod)

NODE_ENV=production
PORT=3000
REGION=us-east-1

# Database Configuration (from AWS Secrets Manager)
DATABASE_URL=postgres://postgres:password@ecommerce-db-prod.xxxxxx.rds.amazonaws.com:5432/ecommerce

# JWT Configuration (from AWS Secrets Manager)
JWT_SECRET=production-secret-key-from-secrets-manager

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# API Configuration
API_BASE_URL=https://api.example.com
API_TIMEOUT=30000

# Logging
LOG_LEVEL=warn
LOG_FORMAT=json

# Feature Flags
ENABLE_DETAILED_MONITORING=true
ENABLE_DETAILED_LOGGING=false

# Email Configuration
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-username
SMTP_FROM=noreply@example.com

# Security
CORS_ORIGIN=https://example.com
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
