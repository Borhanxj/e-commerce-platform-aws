# Invoice Service Configuration Example (.env.example for services/invoice/)

# Application
ENVIRONMENT=development

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Email/SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Logging
LOG_LEVEL=debug
